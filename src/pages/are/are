    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Quelle est la différence entre ARE brute et ARE nette ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "L'ARE brute correspond au montant avant prélèvements sociaux. L'ARE nette est le montant que vous recevez réellement après déduction de la CSG (6,2%) et de la CRDS (0,5%), soit un total de 6,7% de prélèvements. Certains allocataires sont exonérés de CSG/CRDS selon leurs revenus."
            }
          },
          {
            "@type": "Question",
            "name": "Combien vais-je toucher net avec l'ARE en 2026 ?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Pour obtenir votre ARE nette, retirez 6,7% du montant brut (CSG 6,2% + CRDS 0,5%). Exemple : ARE brute = 1 200 € → ARE nette ≈ 1 119,60 €. Si vos revenus sont très modestes, vous pouvez être exonéré de CSG/CRDS et toucher l'intégralité de l'ARE brute."
            }
          }
        ]
      }
    </script>
