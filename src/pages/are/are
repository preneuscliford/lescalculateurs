      <section class="mb-8 bg-white rounded-lg shadow-lg p-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">
          🧮 Convertissez votre ARE brute en net
        </h2>
        <div class="bg-blue-50 border-l-4 border-blue-500 p-6 rounded-lg mb-6">
          <h3 class="font-semibold text-gray-900 mb-2">Formule simple</h3>
          <p class="text-xl font-bold text-gray-800">ARE nette 2026 = ARE brute × (1 − 0,067)</p>
          <p class="text-sm text-gray-600 mt-1">Soit ARE brute × 93,3%</p>
        </div>

        <div class="overflow-x-auto mb-6">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-green-100">
                <th class="p-3 text-left border border-gray-300">ARE brute mensuelle</th>
                <th class="p-3 text-left border border-gray-300">Prélèvements (6,7%)</th>
