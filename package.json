{
  "name": "les-calculateurs",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/verify-utf8.cjs && tsc && vite build && node scripts/copy-seo-pages.js && node scripts/clean-satellite-pages.cjs --target=dist && node scripts/add-satellites-to-sitemap.cjs && node scripts/verify-utf8.cjs",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "format": "prettier --write \"{src,data,scripts,docs,public}/**/*.{html,js,cjs,mjs,ts,json,md,xml}\"",
    "format:check": "prettier --check \"{src,data,scripts,docs,public}/**/*.{html,js,cjs,mjs,ts,json,md,xml}\"",
    "generate:blog": "node scripts/generate-departement-articles.js",
    "indexing:publish": "node scripts/publish-indexing.js --from-sitemap",
    "sitemap:normalize": "node scripts/normalize-sitemap-domain.js",
    "sitemap:satellites": "node scripts/add-satellites-to-sitemap.cjs",
    "utf8:check": "node scripts/verify-utf8.cjs",
    "utf8:check:pseo": "node scripts/verify-utf8.cjs --scope=pseo",
    "utf8:fix": "node scripts/fix-utf8-build.cjs",
    "utf8:fix:pseo": "node scripts/fix-utf8-build.cjs --scope=pseo",
    "text:normalize": "node scripts/normalize-french-text.cjs --scope=full --write",
    "text:normalize:pseo": "node scripts/normalize-french-text.cjs --scope=pseo-rendered --html-mode=visible --write",
    "text:normalize:seo:pseo": "node scripts/normalize-french-text.cjs --scope=pseo-rendered --html-mode=seo --write",
    "text:normalize:check": "node scripts/normalize-french-text.cjs --scope=full --html-mode=all --check",
    "text:normalize:check:pseo": "node scripts/normalize-french-text.cjs --scope=pseo-rendered --html-mode=visible --check",
    "text:normalize:check:seo:pseo": "node scripts/normalize-french-text.cjs --scope=pseo-rendered --html-mode=seo --check",
    "text:languagetool:pseo": "node scripts/check-french-with-languagetool.cjs --scope=pseo-rendered",
    "satellites:clean:src": "node scripts/clean-satellite-pages.cjs --target=src",
    "satellites:clean:dist": "node scripts/clean-satellite-pages.cjs --target=dist",
    "agent:official": "node scripts/official-data-agent.cjs",
    "agent:official:due": "node scripts/official-data-agent.cjs --fetch-all=false",
    "sync:impot": "node scripts/sync-impot-from-baremes.cjs",
    "sync:apl": "node scripts/sync-apl-from-baremes.cjs",
    "agent:juridique:apl": "node scripts/agent-juridique.cjs --cluster=apl --due=true",
    "agent:juridique:ir": "node scripts/agent-juridique.cjs --cluster=ir --due=true",
    "agent:juridique:ik": "node scripts/agent-juridique.cjs --cluster=ik --due=true",
    "agent:juridique:notaire": "node scripts/agent-juridique.cjs --cluster=notaire --due=true",
    "agent:juridique:dmto": "node scripts/agent-juridique.cjs --cluster=dmto --due=true",
    "adsense:go-live-check": "node scripts/adsense-go-live-check.cjs",
    "generate:pseo:apl": "node scripts/generate-pseo-apl.js",
    "generate:pseo:apl:dist": "node scripts/generate-pseo-apl.js --target=dist",
    "generate:pseo:rsa": "node scripts/generate-pseo-rsa.js",
    "generate:pseo:are": "node scripts/generate-pseo-are.js",
    "qa:pseo": "npm run utf8:check:pseo && npm run text:normalize:check:pseo && npm run format:check && npm run text:languagetool:pseo"
  },
  "blog:update:2026": "node scripts/update-blog-pages.cjs",
  "blog:revert": "node scripts/revert-blog-pages.cjs",
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "chart.js": "^4.5.1",
    "google-auth-library": "^9.14.3",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "autoprefixer": "^10.4.16",
    "chardet": "^2.1.1",
    "iconv-lite": "^0.7.2",
    "jest": "^30.2.0",
    "node-html-parser": "^7.1.0",
    "parse5": "^8.0.0",
    "postcss": "^8.4.32",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.3.6",
    "ts-jest": "^29.4.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}
