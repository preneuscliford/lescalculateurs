{
  "name": "les-calculateurs",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "utf8:validate": "node scripts/validate-utf8-gate.cjs",
    "utf8:check-integrity": "node scripts/check-integrity.cjs",
    "utf8:cleanup": "node scripts/cleanup-emergency.cjs",
    "utf8:diagnose": "node scripts/diagnose-encoding.cjs",
    "safe-run": "node scripts/safe-run.cjs",
    "dev": "vite",
    "build": "node scripts/verify-utf8.cjs && tsc && vite build && node scripts/verify-utf8.cjs",
    "build:publish": "npm run build && node scripts/copy-seo-pages.js && node scripts/clean-satellite-pages.cjs --target=dist && node scripts/add-satellites-to-sitemap.cjs",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "format": "prettier --write \"{src,data,scripts,docs,public}/**/*.{html,js,cjs,mjs,ts,json,md,xml}\"",
    "format:check": "prettier --check \"{src,data,scripts,docs,public}/**/*.{html,js,cjs,mjs,ts,json,md,xml}\"",
    "generate:blog": "node scripts/generate-departement-articles.js",
    "indexing:publish": "node scripts/publish-indexing.js --from-sitemap",
    "sitemap:normalize": "node scripts/normalize-sitemap-domain.js",
    "sitemap:satellites": "node scripts/add-satellites-to-sitemap.cjs",
    "utf8:check": "node scripts/verify-utf8.cjs --scope=repo",
    "utf8:check:pseo": "node scripts/verify-utf8.cjs --scope=pseo",
    "utf8:check:publish:pseo": "node scripts/verify-utf8.cjs --scope=publish-pseo",
    "utf8:fix": "node scripts/fix-utf8-build.cjs",
    "utf8:fix:pseo": "node scripts/fix-utf8-build.cjs --scope=pseo",
    "text:normalize": "node scripts/normalize-french-text.cjs --scope=full --write",
    "text:normalize:pseo": "node scripts/normalize-french-text.cjs --scope=pseo-rendered --html-mode=visible --write",
    "text:normalize:seo:pseo": "node scripts/normalize-french-text.cjs --scope=pseo-rendered --html-mode=seo --write",
    "text:normalize:check": "node scripts/normalize-french-text.cjs --scope=full --html-mode=all --check",
    "text:normalize:check:pseo": "node scripts/normalize-french-text.cjs --scope=pseo-rendered --html-mode=visible --check",
    "text:normalize:check:seo:pseo": "node scripts/normalize-french-text.cjs --scope=pseo-rendered --html-mode=seo --check",
    "text:normalize:pilot20": "node scripts/normalize-french-text.cjs --scope=french-pilot-20 --html-mode=visible --write && node scripts/normalize-french-text.cjs --scope=french-pilot-20 --html-mode=seo --write",
    "text:normalize:check:pilot20": "node scripts/normalize-french-text.cjs --scope=french-pilot-20 --html-mode=visible --check && node scripts/normalize-french-text.cjs --scope=french-pilot-20 --html-mode=seo --check",
    "text:languagetool:pseo": "node scripts/check-french-with-languagetool.cjs --scope=pseo-rendered",
    "text:languagetool:publish:pseo": "node scripts/check-french-with-languagetool.cjs --scope=pseo-rendered",
    "text:languagetool:pilot20": "node scripts/check-french-with-languagetool.cjs --scope=french-pilot-20",
    "text:openai:simulateurs": "node scripts/check-french-with-openai.cjs --scope=simulateurs-rendered --mode=visible --limit=200 --output=openai-french-review-simulateurs-visible-v1",
    "text:openai:simulateurs:seo": "node scripts/check-french-with-openai.cjs --scope=simulateurs-rendered --mode=seo --limit=200 --output=openai-french-review-simulateurs-seo-v1",
    "text:openai:pilot20": "node scripts/check-french-with-openai.cjs --scope=french-pilot-20 --mode=visible --output=openai-french-review-pilot20-visible-v1",
    "text:openai:pilot20:seo": "node scripts/check-french-with-openai.cjs --scope=french-pilot-20 --mode=seo --output=openai-french-review-pilot20-seo-v1",
    "text:openai:pseo": "node scripts/check-french-with-openai.cjs --scope=pseo-rendered --mode=visible --index-only --limit=500 --output=openai-french-review-pseo-visible-v1",
    "text:openai:pseo:seo": "node scripts/check-french-with-openai.cjs --scope=pseo-rendered --mode=seo --index-only --limit=500 --output=openai-french-review-pseo-seo-v1",
    "text:openai:pillars": "node scripts/check-french-with-openai.cjs --scope=pillars-rendered --mode=visible --limit=200 --output=openai-french-review-pillars-visible-v1",
    "text:openai:pillars:seo": "node scripts/check-french-with-openai.cjs --scope=pillars-rendered --mode=seo --limit=200 --output=openai-french-review-pillars-seo-v1",
    "text:hybrid:pilot20": "node scripts/run-french-hybrid.cjs --scope=french-pilot-20",
    "report:openai:safe:pilot20": "node scripts/report-openai-safe-candidates.cjs --input=reports/openai-french-review-pilot20-visible-v1.json",
    "apply:openai:safe:pilot20": "node scripts/apply-openai-safe-candidates.cjs --input=reports/openai-french-review-pilot20-visible-v1.json",
    "report:pseo": "node scripts/report-pseo-quality.cjs --scope=pseo-rendered",
    "report:site": "node scripts/report-site-quality.cjs --scope=site-rendered",
    "report:pilot20": "node scripts/report-site-quality.cjs --scope=french-pilot-20",
    "qa:publish:pseo": "node scripts/qa-pseo-gate.cjs --scope=publish-pseo",
    "qa:site": "npm run utf8:check && node scripts/normalize-french-text.cjs --scope=site-rendered --html-mode=visible --check && node scripts/normalize-french-text.cjs --scope=site-rendered --html-mode=seo --check && node scripts/check-french-with-languagetool.cjs --scope=site-rendered && npm run report:site",
    "qa:pilot20": "node scripts/verify-utf8.cjs --scope=french-pilot-20 && npm run text:normalize:check:pilot20 && npm run text:languagetool:pilot20 && npm run report:pilot20",
    "satellites:clean:src": "node scripts/clean-satellite-pages.cjs --target=src",
    "satellites:clean:dist": "node scripts/clean-satellite-pages.cjs --target=dist",
    "agent:official": "node scripts/official-data-agent.cjs",
    "agent:official:due": "node scripts/official-data-agent.cjs --fetch-all=false",
    "sync:impot": "node scripts/sync-impot-from-baremes.cjs",
    "sync:apl": "node scripts/sync-apl-from-baremes.cjs",
    "agent:juridique:apl": "node scripts/agent-juridique.cjs --cluster=apl --due=true",
    "agent:juridique:ir": "node scripts/agent-juridique.cjs --cluster=ir --due=true",
    "agent:juridique:ik": "node scripts/agent-juridique.cjs --cluster=ik --due=true",
    "agent:juridique:notaire": "node scripts/agent-juridique.cjs --cluster=notaire --due=true",
    "agent:juridique:dmto": "node scripts/agent-juridique.cjs --cluster=dmto --due=true",
    "adsense:go-live-check": "node scripts/adsense-go-live-check.cjs",
    "generate:pseo:apl": "node scripts/generate-pseo-apl.js",
    "generate:pseo:apl:dist": "node scripts/generate-pseo-apl.js --target=dist",
    "generate:pseo:rsa": "node scripts/generate-pseo-rsa.js",
    "generate:pseo:are": "node scripts/generate-pseo-are.js",
    "qa:pseo": "npm run utf8:check:pseo && npm run text:normalize:check:pseo && npm run format:check && npm run text:languagetool:pseo"
  },
  "blog:update:2026": "node scripts/update-blog-pages.cjs",
  "blog:revert": "node scripts/revert-blog-pages.cjs",
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "chart.js": "^4.5.1",
    "google-auth-library": "^9.14.3",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "autoprefixer": "^10.4.16",
    "chardet": "^2.1.1",
    "iconv-lite": "^0.7.2",
    "jest": "^30.2.0",
    "node-html-parser": "^7.1.0",
    "parse5": "^8.0.0",
    "postcss": "^8.4.32",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.3.6",
    "ts-jest": "^29.4.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}
